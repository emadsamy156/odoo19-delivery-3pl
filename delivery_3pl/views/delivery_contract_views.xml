<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_delivery_contract_tree" model="ir.ui.view">
        <field name="name">delivery.contract.tree</field>
        <field name="model">delivery.contract</field>
        <field name="arch" type="xml">
            <tree string="Contracts" decoration-success="status == 'active'"
                  decoration-muted="status in ('expired', 'terminated')">
                <field name="company_id"/>
                <field name="branch_id" optional="show"/>
                <field name="contract_number"/>
                <field name="version"/>
                <field name="contract_type" widget="badge"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'active'"
                       decoration-info="status == 'draft'"
                       decoration-warning="status == 'expired'"
                       decoration-danger="status == 'terminated'"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="settlement_cycle"/>
                <field name="pricing_rule_count" string="Rules"/>
                <field name="auto_renew"/>
            </tree>
        </field>
    </record>

    <record id="view_delivery_contract_form" model="ir.ui.view">
        <field name="name">delivery.contract.form</field>
        <field name="model">delivery.contract</field>
        <field name="arch" type="xml">
            <form string="Contract">
                <header>
                    <button name="action_activate" type="object" string="Activate"
                            class="oe_highlight"
                            invisible="status != 'draft'"/>
                    <button name="action_terminate" type="object" string="Terminate"
                            class="btn-danger"
                            invisible="status != 'active'"
                            confirm="Are you sure you want to terminate this contract?"/>
                    <button name="action_renew" type="object" string="Renew"
                            invisible="status not in ('active', 'expired')"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,active,expired"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="contract_number" placeholder="Contract Number"/>
                            <span class="text-muted"> v</span>
                            <field name="version" class="oe_inline"/>
                        </h1>
                    </div>
                    <group>
                        <group string="General">
                            <field name="company_id"/>
                            <field name="branch_id"/>
                            <field name="contract_type"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="auto_renew"/>
                        </group>
                        <group string="Financial Terms">
                            <field name="settlement_cycle"/>
                            <field name="commission_rate"/>
                            <field name="payment_terms_days"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Pricing Rules" name="pricing">
                            <field name="pricing_rule_ids">
                                <tree string="Pricing Rules">
                                    <field name="name"/>
                                    <field name="company_id" column_invisible="1"/>
                                    <field name="branch_id" column_invisible="1"/>
                                    <field name="city_id"/>
                                    <field name="pricing_type" widget="badge"/>
                                    <field name="vehicle_type"/>
                                    <field name="base_amount"/>
                                    <field name="per_km_amount" optional="show"/>
                                    <field name="daily_rate" optional="show"/>
                                    <field name="slab_count" string="Slabs"/>
                                    <field name="incentive_level_count" string="Levels"/>
                                    <field name="effective_from"/>
                                    <field name="is_active"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Validity Criteria" name="validity">
                            <field name="validity_criteria_ids">
                                <tree string="Validity Criteria" editable="bottom">
                                    <field name="name"/>
                                    <field name="min_daily_online_hours"/>
                                    <field name="min_valid_days"/>
                                    <field name="min_monthly_orders"/>
                                    <field name="must_attend_first_days"/>
                                    <field name="must_attend_last_days"/>
                                    <field name="must_attend_min_valid"/>
                                    <field name="is_active"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Experience Score Config" name="experience">
                            <field name="experience_config_ids">
                                <tree string="Experience Score Config" editable="bottom">
                                    <field name="name"/>
                                    <field name="on_time_delivery_weight"/>
                                    <field name="cancellation_rate_weight"/>
                                    <field name="advance_delivery_weight"/>
                                    <field name="min_orders_for_ranking"/>
                                    <field name="only_valid_da_eligible"/>
                                    <field name="is_active"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Company Targets" name="targets">
                            <field name="company_target_ids">
                                <tree string="Company Targets">
                                    <field name="period_display"/>
                                    <field name="actual_valid_das"/>
                                    <field name="achieved_level"/>
                                    <field name="target_met"/>
                                    <field name="tga_excl_vat"/>
                                    <field name="total_due"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Settlements" name="settlements">
                            <field name="settlement_ids">
                                <tree string="Settlements">
                                    <field name="settlement_number"/>
                                    <field name="period_start"/>
                                    <field name="period_end"/>
                                    <field name="total_orders"/>
                                    <field name="net_amount"/>
                                    <field name="status" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Import Sessions" name="imports">
                            <field name="import_session_ids">
                                <tree string="Imports">
                                    <field name="file_name"/>
                                    <field name="import_date"/>
                                    <field name="total_rows"/>
                                    <field name="valid_rows"/>
                                    <field name="error_rows"/>
                                    <field name="status" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Policies" name="policies">
                            <group>
                                <field name="penalty_policy"/>
                                <field name="deposit_policy"/>
                            </group>
                        </page>
                        <page string="Column Mapping (خريطة الأعمدة)" name="mapping">
                            <div class="alert alert-info mb-3" role="alert">
                                <strong>خريطة أعمدة Excel:</strong>
                                حدد أسماء الأعمدة في ملف Excel لكل حقل. يمكن تحديد عدة أسماء بديلة لكل حقل.
                                <br/>إذا تُركت فارغة، سيتم استخدام الأسماء الافتراضية تلقائياً (عربي/إنجليزي).
                                <br/><br/>
                                <strong>مثال:</strong>
                                <pre style="font-size: 12px; margin-top: 5px;">{
    "order_id": ["رقم الطلب", "Order ID", "order_no"],
    "rider_phone": ["هاتف", "phone", "Mobile"],
    "rider_name": ["اسم الحساب", "Rider Name", "name"],
    "rider_account_id": ["معرف الحساب", "Account ID", "rider_id"],
    "city_name": ["المدينة", "City"],
    "order_date": ["التاريخ", "Date"],
    "distance": ["المسافة", "Distance"],
    "platform_amount": ["المبلغ", "Amount"]
}</pre>
                            </div>
                            <field name="column_mapping" widget="code" options="{'language': 'json'}"/>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_delivery_contract_search" model="ir.ui.view">
        <field name="name">delivery.contract.search</field>
        <field name="model">delivery.contract</field>
        <field name="arch" type="xml">
            <search string="Search Contracts">
                <field name="contract_number"/>
                <field name="company_id"/>
                <field name="branch_id"/>
                <filter name="active_status" string="Active" domain="[('status', '=', 'active')]"/>
                <filter name="draft_status" string="Draft" domain="[('status', '=', 'draft')]"/>
                <filter name="expired_status" string="Expired" domain="[('status', '=', 'expired')]"/>
                <separator/>
                <filter name="type_parcel" string="Parcel" domain="[('contract_type', '=', 'parcel')]"/>
                <filter name="type_service" string="Service" domain="[('contract_type', '=', 'service')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_company" string="Company" context="{'group_by': 'company_id'}"/>
                    <filter name="group_branch" string="Branch" context="{'group_by': 'branch_id'}"/>
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                    <filter name="group_type" string="Contract Type" context="{'group_by': 'contract_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_delivery_contract" model="ir.actions.act_window">
        <field name="name">Contracts</field>
        <field name="res_model">delivery.contract</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_company': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first contract</p>
            <p>Contracts are versioned per company branch. Only one active version per branch at a time. A contract can have multiple pricing rules.</p>
        </field>
    </record>
</odoo>
