<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_delivery_3pl" model="ir.module.category">
        <field name="name">3PL Delivery</field>
        <field name="description">Access rights for 3PL Delivery Operations Management</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_delivery_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_delivery_3pl"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_delivery_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_delivery_3pl"/>
        <field name="implied_ids" eval="[(4, ref('group_delivery_user'))]"/>
    </record>

    <record id="group_delivery_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_category_delivery_3pl"/>
        <field name="implied_ids" eval="[(4, ref('group_delivery_manager'))]"/>
    </record>
</odoo>
