<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_delivery_city_tree" model="ir.ui.view">
        <field name="name">delivery.city.tree</field>
        <field name="model">delivery.city</field>
        <field name="arch" type="xml">
            <tree string="Cities">
                <field name="name"/>
                <field name="name_ar"/>
                <field name="tier" widget="badge"/>
                <field name="is_active"/>
            </tree>
        </field>
    </record>

    <record id="view_delivery_city_form" model="ir.ui.view">
        <field name="name">delivery.city.form</field>
        <field name="model">delivery.city</field>
        <field name="arch" type="xml">
            <form string="City">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="name_ar"/>
                        </group>
                        <group>
                            <field name="tier"/>
                            <field name="is_active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_delivery_city_search" model="ir.ui.view">
        <field name="name">delivery.city.search</field>
        <field name="model">delivery.city</field>
        <field name="arch" type="xml">
            <search string="Search Cities">
                <field name="name"/>
                <field name="name_ar"/>
                <filter name="t1" string="T1 Major" domain="[('tier', '=', 'T1')]"/>
                <filter name="t2" string="T2 Mid" domain="[('tier', '=', 'T2')]"/>
                <filter name="t3" string="T3 Small" domain="[('tier', '=', 'T3')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_tier" string="Tier" context="{'group_by': 'tier'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_delivery_city" model="ir.actions.act_window">
        <field name="name">Cities</field>
        <field name="res_model">delivery.city</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
