<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_delivery_import_session_tree" model="ir.ui.view">
        <field name="name">delivery.import.session.tree</field>
        <field name="model">delivery.import.session</field>
        <field name="arch" type="xml">
            <tree string="Import Sessions" decoration-danger="status == 'failed'"
                  decoration-success="status == 'imported'">
                <field name="file_name"/>
                <field name="company_id"/>
                <field name="branch_id" optional="show"/>
                <field name="contract_id" optional="hide"/>
                <field name="import_date"/>
                <field name="period_start"/>
                <field name="period_end"/>
                <field name="total_rows"/>
                <field name="valid_rows"/>
                <field name="error_rows"/>
                <field name="total_amount"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'imported'"
                       decoration-info="status == 'validated'"
                       decoration-warning="status == 'pending'"
                       decoration-danger="status == 'failed'"/>
                <field name="imported_by"/>
            </tree>
        </field>
    </record>

    <record id="view_delivery_import_session_form" model="ir.ui.view">
        <field name="name">delivery.import.session.form</field>
        <field name="model">delivery.import.session</field>
        <field name="arch" type="xml">
            <form string="Import Session">
                <header>
                    <button name="action_parse_file" type="object" string="Process File (معالجة الملف)"
                            class="oe_highlight"
                            invisible="status != 'pending'"
                            confirm="سيتم معالجة الملف وإنشاء صفوف الاستيراد. هل تريد المتابعة؟"/>
                    <button name="action_validate" type="object" string="Validate (تحقق)"
                            class="oe_highlight"
                            invisible="status != 'pending'"/>
                    <button name="action_confirm" type="object" string="Confirm Import (تأكيد)"
                            class="oe_highlight"
                            invisible="status != 'validated'"/>
                    <button name="action_mark_failed" type="object" string="Mark as Failed"
                            invisible="status not in ('pending', 'validated')"/>
                    <button name="action_reset_to_pending" type="object" string="Reset (إعادة)"
                            invisible="status not in ('failed', 'validated')"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="pending,validated,imported"/>
                </header>
                <sheet>
                    <group>
                        <group string="Import Details (تفاصيل الاستيراد)">
                            <field name="company_id" readonly="status != 'pending'"/>
                            <field name="branch_id" readonly="status != 'pending'"/>
                            <field name="contract_id" readonly="status != 'pending'"/>
                            <field name="file_name" readonly="status != 'pending'"/>
                            <field name="file_data" filename="file_name" readonly="status != 'pending'"/>
                            <field name="sheet_name" readonly="status != 'pending'"
                                   placeholder="اتركه فارغاً للورقة الأولى"/>
                            <field name="import_date" readonly="status != 'pending'"/>
                            <field name="imported_by"/>
                        </group>
                        <group string="Period &amp; Statistics">
                            <field name="period_start"/>
                            <field name="period_end"/>
                            <field name="total_rows"/>
                            <field name="valid_rows"/>
                            <field name="error_rows"/>
                            <field name="total_amount"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Import Rows (صفوف الاستيراد)" name="rows">
                            <field name="row_count" invisible="1"/>
                            <div class="alert alert-info" role="alert"
                                 invisible="row_count > 0">
                                <strong>لم يتم معالجة الملف بعد.</strong>
                                ارفع ملف Excel ثم اضغط "Process File (معالجة الملف)" لاستخراج البيانات.
                            </div>
                            <field name="row_ids" readonly="status != 'pending'">
                                <tree string="Rows" decoration-danger="status == 'error'"
                                      decoration-success="status == 'valid'"
                                      decoration-muted="status == 'pending'"
                                      editable="bottom">
                                    <field name="row_number" string="#"/>
                                    <field name="order_id" string="معرف الحساب"/>
                                    <field name="rider_name" string="اسم الحساب"/>
                                    <field name="rider_user" string="مستخدم الحساب" optional="show"/>
                                    <field name="rider_id" string="المندوب المطابق"/>
                                    <field name="rider_phone" optional="show"/>
                                    <field name="vehicle_type_company" string="مركبة الشركة" optional="show"/>
                                    <field name="vehicle_type_contract" string="مركبة العقد" optional="show"/>
                                    <field name="plate_number" string="رقم اللوحة" optional="hide"/>
                                    <field name="platform_target" string="تارجت المنصة" optional="show"/>
                                    <field name="company_target_val" string="تارجت الشركة" optional="show"/>
                                    <field name="accepted_tasks" string="مقبولة" optional="show"/>
                                    <field name="delivered_tasks" string="مسلّمة" optional="show"/>
                                    <field name="large_orders_completed" string="طلبات كبيرة" optional="hide"/>
                                    <field name="cancelled_tasks" string="ملغاة" optional="show"/>
                                    <field name="rejected_tasks" string="مرفوضة" optional="show"/>
                                    <field name="driver_rejected" string="رفض سائق" optional="hide"/>
                                    <field name="auto_rejected" string="رفض تلقائي" optional="hide"/>
                                    <field name="online_hours" string="ساعات اتصال" optional="show"/>
                                    <field name="ontime_rate" string="نسبة التوقيت" optional="show"/>
                                    <field name="large_ontime_rate" optional="hide"/>
                                    <field name="avg_delivery_duration" string="متوسط التوصيل" optional="hide"/>
                                    <field name="over_55min_rate" optional="hide"/>
                                    <field name="late_tasks" string="متأخرة" optional="hide"/>
                                    <field name="very_late_tasks" string="متأخرة جداً" optional="hide"/>
                                    <field name="fuel" string="بنزين" optional="show"/>
                                    <field name="city_name" optional="hide"/>
                                    <field name="city_id" optional="hide"/>
                                    <field name="order_date" optional="hide"/>
                                    <field name="distance" optional="hide"/>
                                    <field name="platform_amount" optional="hide"/>
                                    <field name="calculated_amount" optional="hide"/>
                                    <field name="variance" optional="hide"/>
                                    <field name="status" widget="badge"
                                           decoration-success="status == 'valid'"
                                           decoration-danger="status == 'error'"
                                           decoration-warning="status == 'pending'"/>
                                    <field name="error_message" optional="show"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Error Log" name="errors">
                            <field name="error_log"/>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_delivery_import_session_search" model="ir.ui.view">
        <field name="name">delivery.import.session.search</field>
        <field name="model">delivery.import.session</field>
        <field name="arch" type="xml">
            <search string="Search Imports">
                <field name="file_name"/>
                <field name="company_id"/>
                <field name="branch_id"/>
                <filter name="pending" string="Pending" domain="[('status', '=', 'pending')]"/>
                <filter name="validated" string="Validated" domain="[('status', '=', 'validated')]"/>
                <filter name="imported" string="Imported" domain="[('status', '=', 'imported')]"/>
                <filter name="failed" string="Failed" domain="[('status', '=', 'failed')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_company" string="Company" context="{'group_by': 'company_id'}"/>
                    <filter name="group_branch" string="Branch" context="{'group_by': 'branch_id'}"/>
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_delivery_import_session" model="ir.actions.act_window">
        <field name="name">Import Sessions</field>
        <field name="res_model">delivery.import.session</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Upload your first delivery data file</p>
            <p>Import Excel files from delivery platforms with automatic validation.</p>
        </field>
    </record>
</odoo>
